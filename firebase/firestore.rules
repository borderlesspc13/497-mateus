rules_version = '2';

// App usa Firebase Auth (e-mail/senha) no browser.
// Usuários autenticados podem ler/escrever nas coleções operacionais.

service cloud.firestore {
  match /databases/{database}/documents {

    match /administradoras/{docId} {
      allow read, write: if request.auth != null;
    }
    match /planos/{docId} {
      allow read, write: if request.auth != null;
    }
    match /vendas/{docId} {
      allow read, write: if request.auth != null;
    }
    match /consorciados/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
